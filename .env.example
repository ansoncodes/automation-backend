# =============================================================================
# SMEC Backend — Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
#
# HOW IT WORKS:
#   - All variables have safe defaults for local development.
#   - To go to production, just change the relevant variables below.
#   - There is only one settings file (smec/settings.py) — no switching needed.
# =============================================================================

# ----------------------------------------------------------------------------
# Django Core (required)
# ----------------------------------------------------------------------------
# ⚠ PRODUCTION WARNING: You MUST replace this with a securely generated key.
# NEVER use the placeholder value in production — it is publicly known.
# Generate a secure key with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=your-secret-key-here

# Set to False in production
DJANGO_DEBUG=True

# Comma-separated list — add your domain in production
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# ----------------------------------------------------------------------------
# Database
# Dev default: SQLite — no further config needed.
# Production:  Uncomment and fill in the PostgreSQL variables below.
# ----------------------------------------------------------------------------
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=smec_leads
# DB_USER=smec_user
# DB_PASSWORD=strongpassword
# DB_HOST=localhost
# DB_PORT=5432

# ----------------------------------------------------------------------------
# File Storage
# Dev default: local filesystem (files saved to media/).
# Production:  Set USE_S3=True and fill in the AWS/R2 credentials below.
# ----------------------------------------------------------------------------
USE_S3=False
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_STORAGE_BUCKET_NAME=smec-rfq-files
# AWS_S3_REGION_NAME=ap-south-1

# ----------------------------------------------------------------------------
# Email
# ----------------------------------------------------------------------------
# Email sending is not configured — removed from this project

BASE_URL=http://localhost:8000

# ----------------------------------------------------------------------------
# CORS
# Default (when this var is unset): False — origins are blocked.
# Dev:        Set CORS_ALLOW_ALL_ORIGINS=True to allow all origins locally.
# Production: Leave False and list your exact domains in CORS_ALLOWED_ORIGINS.
# ----------------------------------------------------------------------------
CORS_ALLOW_ALL_ORIGINS=True
# CORS_ALLOWED_ORIGINS=https://smecoilandgas.com,https://www.smecautomation.com

# ----------------------------------------------------------------------------
# Google Sheets Integration
# Path to the service account JSON key file downloaded from Google Cloud.
# The service account must have Editor access to the target spreadsheet.
# Leave the sheets_id field blank on any Campaign to skip Sheets for that page.
# ----------------------------------------------------------------------------
GOOGLE_SERVICE_ACCOUNT_JSON=service_account.json
